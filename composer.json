{
  "name": "hukka/yii2-weather-api",
  "description": "Yii2 + PostgreSQL weather API project with request history",
  "type": "project",
  "license": "MIT",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "require": {
    "php": ">=8.1",
    "yiisoft/yii2": "~2.0.52"
  },
  "autoload": {
    "psr-4": {
      "app\\": ""
    }
  },
  "config": {
    "process-timeout": 1800,
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  }
}
